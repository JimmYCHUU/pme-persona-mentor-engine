{
  "name": "pme-workspace-monitor",
  "displayName": "PME Workspace Monitor",
  "version": "0.1.0",
  "engines": { "vscode": "^1.89.0" },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pme.openChat",
        "title": "PME: Open Mentor Chat"
      }
    ]
  },
  "dependencies": { "axios": "^1.7.0" },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.89.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.26.0"
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json"
  }
}
