# OpenRouter API — get your key at openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models (free tier — verified on OpenRouter)
PERSONA_MODEL=meta-llama/llama-3.3-70b-instruct:free
REASONING_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FALLBACK_MODEL=llama3.2:3b

# Local data paths
CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads
PERSONA_DIR=./data/personas
SESSION_DIR=./data/sessions
MASTERY_CERT_DIR=./data/mastery_certs
SQLITE_URL=sqlite+aiosqlite:///./data/pme.db

# Thresholds
DEVIATION_THRESHOLD=0.65
IDLE_TRIGGER_SECONDS=300
MASTERY_SCORE_INCREMENT=0.1
MASTERY_SCORE_DECREMENT=0.05
MASTERY_CERT_THRESHOLD=0.8
MASTERY_CERT_MIN_SESSIONS=3
MASTERY_CERT_MIN_SUCCESSES=5

# Guardian classifier
GUARDIAN_MODEL=distilbert-base-uncased

# Server
CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
